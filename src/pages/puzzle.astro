<style>
	@keyframes turnOn {
		0% {
			opacity: 1;
		}
		100% {
			opacity: 0;
		}
	}

	@keyframes slideUp {
		0% {
			height: 100%;
		}
		100% {
			height: 0%;
		}
	}
</style>

<div style="display: flex; justify-content: center; align-items: center">
	<svg id="puzzle" style="pointer-events: auto"></svg>
</div>

<script>
	import "../lib/witness/utilities.js";
	import "../lib/witness/svg.js";
	import "../lib/witness/polyominos.js";
	import "../lib/witness/puzzle.js";
	import "../lib/witness/validate.js";
	import "../lib/witness/custom_mechanics.js";
	import "../lib/witness/display2.js";
	import "../lib/witness/trace2.js";

	function bootstrapPuzzle() {
		// 1. Ensure the settings object exists and has defaults
		if (!window.settings) window.settings = {};
		if (!window.settings.theme) window.settings.theme = "light";
		if (!window.settings.sensitivity) window.settings.sensitivity = "0.7";
		if (!window.settings.volume) window.settings.volume = "0.12";

		// 2. Setup the necessary global color palette
		window.BACKGROUND = "#0A8";
		window.OUTER_BACKGROUND = "#113833";
		window.FOREGROUND = "#344";
		window.BORDER = "#000";
		window.LINE_DEFAULT = "#AAA";
		window.LINE_SUCCESS = "#FFF";
		window.LINE_FAIL = "#000";
		window.CURSOR = "#FFF";
		window.TEXT_COLOR = "#000";
		window.PAGE_BACKGROUND = "#FFF";
		window.ALT_BACKGROUND = "#EEE";
		window.ACTIVE_COLOR = "#DDD";

		// 3. Setup the logic constants
		window.LINE_NONE = 0;
		window.LINE_BLACK = 1;
		window.LINE_BLUE = 2;
		window.LINE_YELLOW = 3;
		window.DOT_NONE = 0;
		window.DOT_BLACK = 1;
		window.DOT_BLUE = 2;
		window.DOT_YELLOW = 3;
		window.DOT_INVISIBLE = 4;
		window.GAP_NONE = 0;
		window.GAP_BREAK = 1;
		window.GAP_FULL = 2;
	}

	function initPuzzle() {
		// @ts-ignore
		bootstrapPuzzle();
		const puzzleData =
			'{"grid":[[{"type":"line","line":0,"dir":null,"start":false,"end":null},{"type":"line","line":0,"dir":null,"gap":2,"dot":null,"start":null,"end":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"start":true,"dir":null}],[{"type":"line","line":0,"dir":null,"gap":2,"dot":null,"start":null,"end":null},null,{"type":"line","line":0,"dir":null},{"type":"nonce","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"poly","color":"yellow","polyshape":1,"line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"poly","color":"yellow","polyshape":1,"line":0,"dir":null},{"type":"line","line":0,"dir":null}],[{"type":"line","line":0,"dir":null,"start":false,"end":null},{"type":"line","line":0,"dir":null,"gap":2,"dot":null,"start":null,"end":null},{"type":"line","line":0,"dir":null,"end":"top"},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null},{"type":"line","line":0,"dir":null}]],"largezero":54,"width":3,"height":9,"pillar":false,"settings":{"NEGATIONS_CANCEL_NEGATIONS":true,"SHAPELESS_ZERO_POLY":false,"PRECISE_POLYOMINOS":true,"FLASH_FOR_ERRORS":true,"FAT_STARTPOINTS":false,"CUSTOM_MECHANICS":false},"name":"Unnamed Puzzle","startPoint":{"x":0,"y":8},"hasNegations":false,"hasPolyominos":true}';
		// @ts-ignore
		window.puzzle = Puzzle.deserialize(puzzleData);
		// @ts-ignore
		window.draw(window.puzzle);
	}
	window.onload = initPuzzle;
</script>
