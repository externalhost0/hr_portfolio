	<div id="fire-video" class="fixed inset-0 -z-10 mix-blend-lighten pointer-events-none opacity-95">
		<video
			class="h-full w-full object-cover"
			onloadedmetadata="this.playbackRate = 0.7"
			autoplay
			muted
			loop
			playsinline
		>
			<source src={fireoverlayVideo_webm} type="video/webm" />
			<source src={fireoverlayVideo_mp4} type="video/mp4" />
		</video>
	</div>
    
    <div id="liquid-video" class="opacity-0 fixed inset-0 -z-10 pointer-events-none" style="filter: var(--liquid-filter);">
		<video
            id="liquid-video-element"
			class="h-full w-full object-cover"
			muted
			playsinline
		>
			<source src={liquidDrop2Video_webm} type="video/webm" />
			<source src={liquidDrop2Video_mp4} type="video/mp4" />
		</video>
	</div>
    <div id="color-back" class="opacity-0 w-full h-full fixed inset-0 -z-10 bg-[#eef110]" style="filter: var(--liquid-filter);"></div>
	<script>
		import gsap from "gsap";

        const liquidVid = document.getElementById("liquid-video-element") as HTMLVideoElement;

		document.getElementById("learn-button")?.addEventListener("click", () => {
			const tl = gsap.timeline();
			tl.to("#fire-video", {
				opacity: 0,
				ease: "back.out",
				duration: 1,
			});
			tl.to(
				"#liquid-video",
				{
					opacity: 1,
					ease: "back.in",
					duration: 1,
				},
				"-0.2",
			);
            tl.add(() => {
                if (liquidVid) {
                    liquidVid.currentTime = 0;
                    liquidVid.play();
                }
            }, 1);
            tl.to("#color-back", {
                opacity: 1,
                duration: 1,
            }, "+=2.2")
		});
	</script>
