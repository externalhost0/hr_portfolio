---
import "iconify-icon";

import Hamburger from "./Hamburger";
import NavbarSection from "./NavbarSection.astro";
import AudioToggle from "../misc/AudioToggle";
const pathname = Astro.url.pathname;
---

<div class="grid grid-cols-3 items-center px-8 py-5 text-white bg-black">
	<div class="justify-self-start flex flex-col gap-0">
		<a href="/" data-cursor-lock data-cursor-width="8rem" data-cursor-height="3rem" class="hover:animate-[huerotate_10s_linear_0s_infinite] justify-self-start font-medium text-wide whitespace-nowrap"
			>Hayden Rivas
			<div
				class="ascii-wave w-full h-2 overflow-hidden font-mono text-[10px] leading-none animated-brand-cycle whitespace-nowrap"
				aria-hidden="true"
			>
				<style>
					@keyframes brandcycle {
						0% {
							color: #f76611;
						}
						50% {
							color: #f53c20;
						}
						100% {
							color: #f76611;
						}
					}
					.animated-brand-cycle {
						animation: brandcycle 4s infinite forwards;
					}
				</style>
				<span class="ascii-wave-inner"></span>
			</div>
		</a>
	</div>

	<div class="col-start-3 justify-self-end md:hidden flex items-center">
		<Hamburger client:idle />
	</div>

	<div class="hidden md:flex justify-self-center justify-center">
		<div class="relative flex flex-row justify-evenly items-center gap-1 rounded-sm">
			<!-- <span id="email-text" class="underline active:scale-95 cursor-pointer transition-all duration-300 ease-out" title="Click to copy">@gmail.com</span>
				<script>
