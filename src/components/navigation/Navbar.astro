						});
					}
				</script> -->

			<!-- <NavbarSection title="About" href="/about" isActive={pathname === "/about"} />
			<NavbarSection title="Projects" href="/projects" isActive={pathname === "/projects"} />
			<NavbarSection title="Contact" href="/contact" isActive={pathname === "/contact"} /> -->
		</div>
	</div>

	<div class="hidden md:flex justify-self-end items-center">
		<div class="flex flex-row justify-evenly items-center gap-2">
			<!-- <div class="flex follower items-center mr-4 -translate-y-0.5">
                <AudioToggle client:only="solid-js"/>
            </div> -->
			<a
				href="https://github.com/externalhost0"
				data-cursor-lock
				aria-label="Github Link"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex size-10 items-center justify-center leading-none"
			>
				<iconify-icon
					icon="mdi:github"
					class="text-4xl hover:scale-110 transition-[color,scale] hover:delay-75 hover:text-[#63BB1B]"
				></iconify-icon>
			</a>
			<a
				href="https://linkedin.com/in/hayden-rivas"
				data-cursor-lock
				aria-label="Linkedin Link"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex size-10 items-center justify-center leading-none"
			>
				<iconify-icon
					icon="mdi:linkedin"
					class="text-4xl hover:scale-110 transition-[color,scale] hover:delay-75 hover:text-[#F5993D]"
				></iconify-icon>
			</a>
			<a
				href="mailto:haydenr261@gmail.com"
				data-cursor-lock
				aria-label="Email Link"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex size-10 items-center justify-center leading-none"
			>
				<iconify-icon
					icon="mdi:email"
