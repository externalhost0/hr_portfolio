</div>

<script>
	function updateActiveNav() {
		const path = window.location.pathname;
		document.querySelectorAll<HTMLAnchorElement>("[data-nav-href]").forEach((el) => {
			const href = el.getAttribute("data-nav-href");
			const isActive = href === path;
			el.classList.toggle("bg-neutral-900/95", isActive);
			el.classList.toggle("hover:bg-neutral-800/80", isActive);
			el.classList.toggle("hover:bg-white", !isActive);
			el.classList.toggle("hover:text-black", !isActive);
		});
	}
	document.addEventListener("astro:page-load", updateActiveNav);
	updateActiveNav();

	const waves = document.querySelectorAll<HTMLDivElement>(".ascii-wave");
	const shades = ["░", "▒", "▓", "█"];
	const tickMs = 300;

	waves.forEach((wave) => {
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			wave.textContent = "░░▒▒▓▓██▓▓▒▒";
			return;
		}

		let charCount = 12;
		const runLength = 2;
		const wavelength1 = 12;
		const wavelength2 = 19;
		let offset1 = 0;
		let offset2 = 0;
		let intervalId: number | undefined;

		const updateWidth = () => {
			const charWidth = 6;
			charCount = Math.max(1, Math.floor(wave.clientWidth / charWidth));
		};

		const getSineShade = (index: number) => {
			const sin1 = (Math.sin(((index + offset1) / wavelength1) * Math.PI * 2) + 1) / 2;
			const sin2 = (Math.sin(((index + offset2) / wavelength2) * Math.PI * 2) + 1) / 2;
			return shades[Math.round(((sin1 + sin2) / 2) * (shades.length - 1))];
		};

		const render = () => {
			const sampleCount = Math.ceil(charCount / runLength) + 2;

			wave.textContent = Array.from({ length: sampleCount }, (_, index) => {
				return getSineShade(index).repeat(runLength);
			})
				.join("")
				.slice(0, charCount);
		};

		const start = () => {
			window.clearInterval(intervalId);
			intervalId = window.setInterval(() => {
				offset1 += 1;
				offset2 += 1.6;
				render();
			}, tickMs);
		};

		updateWidth();
		render();
		start();
		window.addEventListener("resize", () => {
			updateWidth();
			render();
		});
	});
</script>
