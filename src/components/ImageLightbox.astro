<dialog class="image-lightbox" data-image-lightbox>
	<div class="image-lightbox-backdrop" data-image-lightbox-backdrop></div>
	<div class="image-lightbox-img-wrap" data-image-lightbox-img-wrap>
		<img class="image-lightbox-img" alt="" data-image-lightbox-img />
	</div>
</dialog>

<style>
	.image-lightbox {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		max-height: none;
		background: transparent;
		border: none;
		outline: none;
		padding: 0;
		margin: 0;
		overflow: hidden;
		z-index: 500;
	}

	.image-lightbox::backdrop {
		display: none;
	}

	.image-lightbox-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.85);
	}

	.image-lightbox-img-wrap {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		pointer-events: none;
	}

	.image-lightbox-img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		user-select: none;
		opacity: 0;
		transition: opacity 180ms ease-out;
		pointer-events: auto;
		cursor: zoom-out;
	}

	.image-lightbox-img.is-loaded {
		opacity: 1;
	}
</style>

<script>
	const EMPTY_IMAGE_SRC =
		"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==";

	const prefersReducedMotion = () =>
		window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	function animateElement(
		element: HTMLElement,
		keyframes: Keyframe[],
		options: KeyframeAnimationOptions,
	) {
		if (prefersReducedMotion()) {
			const finalFrame = keyframes.at(-1);
			if (finalFrame) {
				Object.assign(element.style, finalFrame);
			}
			return Promise.resolve();
		}

		return element.animate(keyframes, options).finished;
	}

	function setupImageLightbox() {
		const dialog = document.querySelector<HTMLDialogElement>("[data-image-lightbox]");
		const lbImg = document.querySelector<HTMLImageElement>("[data-image-lightbox-img]");
		const lbBackdrop = document.querySelector<HTMLElement>("[data-image-lightbox-backdrop]");
		const lbWrap = document.querySelector<HTMLElement>("[data-image-lightbox-img-wrap]");

		if (!dialog || !lbImg || !lbBackdrop || !lbWrap) {
			return;
		}

		const lightboxDialog = dialog;
		const lightboxImg = lbImg;
		const lightboxBackdrop = lbBackdrop;
		const lightboxWrap = lbWrap;

		if (lightboxDialog.dataset.bound !== "1") {
			lightboxDialog.dataset.bound = "1";

			let isOpen = false;
			let isAnimating = false;
			let loadToken = 0;

			async function openLightbox(thumbSrc: string, fullSrc: string, alt: string) {
				if (isOpen || isAnimating) {
					return;
				}

				isOpen = true;
				isAnimating = true;
				loadToken++;
				const myToken = loadToken;

				lightboxImg.src = thumbSrc;
				lightboxImg.alt = alt;
				lightboxImg.classList.add("is-loaded");
				lightboxDialog.showModal();

				lightboxBackdrop.style.opacity = "0";
				lightboxWrap.style.opacity = "0";
				lightboxWrap.style.transform = "scale(0.88)";

				await Promise.all([
					animateElement(
						lightboxBackdrop,
						[{ opacity: "0" }, { opacity: "1" }],
						{ duration: 250, easing: "ease-out", fill: "forwards" },
					),
					animateElement(
						lightboxWrap,
						[
							{ opacity: "0", transform: "scale(0.88)" },
							{ opacity: "1", transform: "scale(1)" },
						],
						{ duration: 300, easing: "ease-out", fill: "forwards" },
					),
				]);
				isAnimating = false;

				if (fullSrc && fullSrc !== thumbSrc) {
					const preload = new Image();
					preload.onload = () => {
						if (myToken !== loadToken) {
							return;
						}
						lightboxImg.src = fullSrc;
					};
					preload.src = fullSrc;
				}
			}

			async function closeLightbox() {
				if (!isOpen || isAnimating) {
					return;
				}

				isAnimating = true;
				loadToken++;
				await Promise.all([
					animateElement(
						lightboxWrap,
						[
							{ opacity: "1", transform: "scale(1)" },
							{ opacity: "0", transform: "scale(1.15)" },
						],
						{ duration: 280, easing: "ease-in", fill: "forwards" },
					),
					animateElement(
						lightboxBackdrop,
						[{ opacity: "1" }, { opacity: "0" }],
						{ duration: 280, easing: "ease-in", fill: "forwards" },
					),
				]);
				lightboxDialog.close();
				lightboxImg.src = EMPTY_IMAGE_SRC;
				lightboxImg.classList.remove("is-loaded");
				isOpen = false;
				isAnimating = false;
			}

			lightboxDialog.addEventListener("click", closeLightbox);
			lightboxDialog.addEventListener("cancel", (e) => {
				e.preventDefault();
				closeLightbox();
			});

			window.addEventListener("image-lightbox:open", (event) => {
				if (!lightboxDialog.isConnected) {
					return;
				}
				const detail = (event as CustomEvent<{ thumbSrc: string; fullSrc: string; alt: string }>).detail;
				if (!detail) {
					return;
				}
				openLightbox(detail.thumbSrc, detail.fullSrc, detail.alt);
			});
		}

		if (document.documentElement.dataset.lightboxDelegated === "1") {
			return;
		}
		document.documentElement.dataset.lightboxDelegated = "1";

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const trigger = target.closest<HTMLElement>("[data-lightbox-trigger]");
			if (!trigger) {
				return;
			}

			const selector = trigger.dataset.lightboxImgSelector || "img";
			const img = trigger.querySelector<HTMLImageElement>(selector);
			if (!img) {
				return;
			}

			const thumbSrc = img.currentSrc || img.src;
			if (!thumbSrc) {
				return;
			}
			const fullSrc = trigger.dataset.lightboxFullSrc || thumbSrc;
			const alt = trigger.dataset.lightboxAlt || img.alt;

			window.dispatchEvent(
				new CustomEvent("image-lightbox:open", {
					detail: { thumbSrc, fullSrc, alt },
				}),
			);
		});
	}

	document.addEventListener("astro:page-load", setupImageLightbox);
</script>
