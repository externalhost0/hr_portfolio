<div id="overlay-top" class="z-100 fixed top-0 inset-x-0 h-1/2 bg-neutral-900"></div>
<div id="overlay-bottom" class="z-100 fixed bottom-0 inset-x-0 h-1/2 bg-neutral-900"></div>

<div id="loading-squares" class="fixed inset-0 z-101 flex items-center justify-center pointer-events-none">
	<div class="grid grid-cols-3 gap-1 w-fit">
		<div class="w-2 h-2 opacity-0 bg-white" data-index="0"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="1"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="2"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="3"></div>
		<div class="w-2 h-2 opacity-0" data-index="center"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="4"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="5"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="6"></div>
		<div class="w-2 h-2 opacity-0 bg-white" data-index="7"></div>
	</div>
</div>

<script>
	import { gsap } from "gsap";

	const INTRO_STORAGE_KEY = "hr-portfolio:intro-seen";
	const LOADER_CYCLE_DURATION = 0.7;
	const LOADER_TOTAL_DURATION = 1.5;
	const LOADER_FADE_MULTIPLIER = 3;
	const introElements = ["#overlay-top", "#overlay-bottom", "#loading-squares"];

	const finishIntro = () => {
		window.dispatchEvent(new CustomEvent("intro:done"));
	};

	const hasSeenIntro = () => {
		try {
			return sessionStorage.getItem(INTRO_STORAGE_KEY) === "true";
		} catch {
			return false;
		}
	};

	const storeIntroSeen = () => {
		try {
			sessionStorage.setItem(INTRO_STORAGE_KEY, "true");
		} catch {
			// Storage can be unavailable in restricted browser contexts.
		}
	};

	if (hasSeenIntro()) {
		document.querySelectorAll(introElements.join(",")).forEach((el) => {
			el.remove();
		});
		finishIntro();
	} else {
		storeIntroSeen();

		gsap.set(introElements, { display: "flex" });
		gsap.set(["#overlay-top", "#overlay-bottom"], { display: "block" });

		const timeline = gsap.timeline();

		const squareSelectors = ["0", "1", "2", "4", "7", "6", "5", "3"];
		const squareElements = squareSelectors.map((idx) =>
			document.querySelector(`#loading-squares [data-index="${idx}"]`),
		);

		gsap.set(squareElements, { opacity: 0.05 });

		const stepDuration = LOADER_CYCLE_DURATION / 8;
		const rotationTl = gsap.timeline();

		const numCycles = Math.ceil(LOADER_TOTAL_DURATION / LOADER_CYCLE_DURATION) + 1;

		for (let cycle = 0; cycle < numCycles; cycle++) {
			const cycleStartTime = cycle * LOADER_CYCLE_DURATION;
			const isLastCycle = cycle === numCycles - 1;

			squareElements.forEach((el, i) => {
				rotationTl.to(
					el,
					{
						opacity: 1,
						duration: stepDuration * 0.15,
						ease: "power2.out",
					},
					cycleStartTime + i * stepDuration,
				);

				const naturalFadeDuration = stepDuration * LOADER_FADE_MULTIPLIER;
				const fadeDuration = isLastCycle
					? Math.min(naturalFadeDuration, (7.95 - i) * stepDuration)
					: naturalFadeDuration;

				rotationTl.to(
					el,
					{
						opacity: 0.05,
						duration: fadeDuration,
						ease: "power2.in",
					},
					cycleStartTime + i * stepDuration + stepDuration * 0.05,
				);
			});
		}

		timeline
			.to("#loading-squares", {
				opacity: 0,
				duration: 0.4,
				delay: LOADER_TOTAL_DURATION,
			})
			.to(
				"#overlay-top",
				{
					yPercent: -100,
					duration: 0.7,
					ease: "power3.inOut",
				},
				"<",
			)
			.to(
				"#overlay-bottom",
				{
					yPercent: 100,
					duration: 0.7,
					ease: "power3.inOut",
				},
				"<",
			)
			.call(() => {
				rotationTl.kill();
			})
			.set(introElements, { display: "none" })
			.call(() => {
				finishIntro();
			});
	}
</script>
