---
import AnimatedArrow from "./misc/AnimatedArrow.astro";
import SideLine from "./misc/SideLine.astro";
---

<div class="relative z-10 flex flex-col items-center pt-20 w-full h-[80dvh]">
	<div class="flex-1 flex flex-col items-center justify-center">
		<p id="nametitle" class="text-4xl md:text-8xl text-white/65 mb-3 text-center">
			hi, i'm <span class="font-medium text-white">hayden rivas</span>
		</p>
		<p class="font-normal text-3xl text-neutral-400 text-center">
			i like to{" "}

			<span class="inline-flex flex-col items-center">
				<span class="text-neutral-300">design</span>
				<span class="relative flex flex-col mr-10 gap-1 mt-2 pr-2">
					<span class="absolute right-0 top-0 w-[2px] bg-neutral-400" style="height: calc(100% - 14px)">
					</span>
					<SideLine>
						<iconify-icon icon="logos:figma"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="logos:blender" width="30"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="vscode-icons:file-type-affinity"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="logos:adobe-photoshop"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="logos:adobe-after-effects"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="logos:adobe-premiere"></iconify-icon>
					</SideLine>
				</span>
			</span>

			{" "}&{" "}

			<span class="inline-flex flex-col items-center">
				<span class="text-neutral-300">build</span>
				<span class="relative flex flex-col mr-10 gap-1 mt-2 pr-2">
					<span class="absolute right-0 top-0 w-[2px] bg-neutral-400" style="height: calc(100% - 14px)">
					</span>
					<SideLine>
						<iconify-icon icon="skill-icons:typescript"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="skill-icons:cpp"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="skill-icons:c"></iconify-icon>
					</SideLine>
					<SideLine>
						<iconify-icon icon="skill-icons:cs"></iconify-icon>
					</SideLine>
				</span>
			</span>

			{" "}software
		</p>
	</div>
	<AnimatedArrow />
	<div id="landingfade" class="w-full h-16 fixed bottom-0 bg-linear-to-b from-transparent to-neutral-700/40">
	</div>
	<script>
		import { gsap } from "../lib/gsap";

		let landingFadeTl: gsap.core.Timeline | null = null;

		function initLandingFade() {
			landingFadeTl?.kill();
			const el = document.getElementById("landingfade");
			if (!el) return;
			gsap.set(el, { clearProps: "all" });
			landingFadeTl = gsap.timeline({
				scrollTrigger: {
					scroller: "#lenis-wrapper",
					trigger: el,
					start: "center 90%",
					end: "+=200",
					scrub: true,
				},
			});
			landingFadeTl.to(el, { opacity: 0, ease: "none" });
			landingFadeTl.to(el, { display: "none" });
		}

		document.addEventListener("astro:page-load", initLandingFade);
	</script>
</div>
