---
import AnimatedArrow from "./misc/AnimatedArrow.astro";
---

<div class="relative z-10 flex flex-col items-center w-full h-[80dvh]">
	<div class="flex-1 flex flex-col items-center justify-center">
		<p id="nametitle" class="text-4xl md:text-8xl text-white/65 mb-3 text-center">
			hi, i'm <span class="font-medium text-white">hayden rivas</span>
		</p>
		<p class="font-normal text-3xl text-neutral-400 text-center">i like to design & build software</p>
	</div>
	<AnimatedArrow />
	<div id="landingfade" class="w-full h-16 fixed bottom-0 bg-linear-to-b from-transparent to-neutral-700/40">
	</div>
	<script>
        import { gsap } from "../lib/gsap";

		let landingFadeTl: gsap.core.Timeline | null = null;

		function initLandingFade() {
			landingFadeTl?.kill();
			const el = document.getElementById("landingfade");
			if (!el) return;
			gsap.set(el, { clearProps: "all" });
			landingFadeTl = gsap.timeline({
				scrollTrigger: {
					scroller: "#lenis-wrapper",
					trigger: el,
					start: "center 90%",
					end: "+=200",
					scrub: true,
				},
			});
			landingFadeTl.to(el, { opacity: 0, ease: "none" });
			landingFadeTl.to(el, { display: "none" });
		}

		document.addEventListener("astro:page-load", initLandingFade);
	</script>
</div>
