---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import ImageLightbox from "./ImageLightbox.astro";

interface Props {
	organization: string;
	role: string;
	timeframe?: string;
	summary: string;
	impact?: string[];
	images?: CaseStudyImageSpot[];
}

interface ImageExtended extends ImageMetadata {
	alt: string;
}

type CaseStudyImageSpot = ImageExtended | ImageExtended[];

const { organization, role, timeframe, summary, impact = [], images = [] } = Astro.props;
const hasBadges = Astro.slots.has("default");
const imageSpots = images.map((image) => (Array.isArray(image) ? image : [image]));
---

<article
	class="case-study-pane overflow-hidden border border-white/10 bg-neutral-950/70"
	data-case-study-pane
>
	<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
		{
			images.length > 0 && (
				<div class="case-study-media grid gap-3 border-b border-white/10 bg-black/40 p-3 lg:border-b-0 lg:border-r">
					{imageSpots.map((spotImages, index) => (
						<div
							class:list={["case-study-image-shell", index === 0 && "is-primary"]}
							data-case-study-img-wrapper
						>
							<button
								type="button"
								class="case-study-img-cycle"
								aria-label="Open case study image"
								data-case-study-img-cycle
								data-lightbox-trigger
								data-lightbox-img-selector=".case-study-image.is-active"
							>
								{spotImages.map((image, imageIndex) => (
									<Image
										src={image}
										format="webp"
										quality={86}
										loading="lazy"
										alt={image.alt}
										class:list={["case-study-image", { "is-active": imageIndex === 0 }]}
									/>
								))}
							</button>
							{spotImages.length > 1 && (
								<div class="case-study-img-dots" data-dot-container>
									{spotImages.map((_, i) => (
										<span class:list={["img-dot", { "is-active": i === 0 }]} />
									))}
								</div>
							)}
						</div>
					))}
				</div>
			)
		}

		<div class="flex min-w-0 flex-col gap-8 p-5">
			<div class="flex flex-col gap-3 md:gap-5 mt-4">
				<div class="min-w-0">
					<div class="flex flex-row justify-between">
						<p class="font-04b text-xs md:text-sm uppercase tracking-widest text-brand-light">{role}</p>
						{timeframe && <p class="portfolio-date-stamp shrink-0">{timeframe}</p>}
					</div>
					<h3 class="mt-2 font-bold text-2xl md:text-5xl leading-none text-neutral-200">{organization}</h3>
				</div>
				{
					hasBadges && (
						<div class="case-study-badges flex flex-wrap gap-0" aria-label="Case study tools/skills">
							<slot />
						</div>
					)
				}
			</div>
			<p
				class="case-study-summary max-w-3xl text-base leading-relaxed text-neutral-300 sm:text-lg"
				set:html={summary}
			/>

			{
				impact.length > 0 && (
					<section class="grid gap-3">
						{/* <p class="text-xs uppercase tracking-widest text-neutral-500">Selected Impact</p> */}
						<ul class="grid gap-3">
							{impact.map((item) => (
								<li class="flex gap-3 text-sm leading-relaxed text-neutral-400 sm:text-base">
									<span class="mt-2.5 block h-1.5 w-1.5 shrink-0 bg-brand-light" aria-hidden="true" />
									<span>{item}</span>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</div>
	</div>

	<ImageLightbox />
</article>

<style>
	.case-study-pane {
		border-radius: 8px;
		box-shadow: 0 24px 90px rgba(0, 0, 0, 0.32);
	}

	.case-study-media {
		align-content: start;
	}

	.case-study-image-shell {
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.04);
	}

	.case-study-img-cycle {
		display: grid;
		align-items: center;
		justify-items: center;
		width: 100%;
		border: 0;
		background: transparent;
		padding: 0;
		cursor: zoom-in;
	}

	.case-study-image {
		grid-area: 1 / 1;
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.45s ease;
	}

	.case-study-image.is-active {
		opacity: 1;
	}

	.case-study-img-dots {
		display: flex;
		justify-content: center;
		gap: 0.375rem;
		padding: 0.625rem 0;
	}

	.img-dot {
		display: block;
		width: 5px;
		height: 5px;
		border-radius: 9999px;
		background-color: rgba(255, 255, 255, 0.25);
		transition:
			background-color 0.3s ease,
			transform 0.3s ease;
	}

	.img-dot.is-active {
		background-color: rgba(255, 255, 255, 0.85);
		transform: scale(1.3);
	}

	.case-study-badges :global(.case-study-badge) {
		display: inline-flex;
		width: 2.25rem;
		height: 2.25rem;
		align-items: center;
		justify-content: center;
	}

	.case-study-summary :global(a) {
		color: rgb(245, 245, 245);
		text-decoration: underline;
		text-decoration-color: rgba(255, 255, 255, 0.35);
		text-underline-offset: 0.18em;
		transition:
			color 160ms ease,
			text-decoration-color 160ms ease;
	}

	.case-study-summary :global(a:hover) {
		color: #f76611;
		text-decoration-color: currentColor;
	}
</style>

<script>
	const cycleInterval = 6000;
	const cycleStagger = 550;

	function setupCaseStudyImageCycles() {
		document.querySelectorAll<HTMLElement>("[data-case-study-img-cycle]").forEach((cycle, cycleIndex) => {
			if (cycle.dataset.cycleBound === "1") {
				return;
			}
			cycle.dataset.cycleBound = "1";

			const images = Array.from(cycle.querySelectorAll<HTMLElement>(".case-study-image"));

			if (images.length < 2) {
				return;
			}

			const wrapper = cycle.closest("[data-case-study-img-wrapper]");
			const dots = wrapper ? Array.from(wrapper.querySelectorAll<HTMLElement>(".img-dot")) : [];

			let activeIndex = 0;

			const showNextImage = () => {
				images[activeIndex].classList.remove("is-active");
				dots[activeIndex]?.classList.remove("is-active");
				activeIndex = (activeIndex + 1) % images.length;
				images[activeIndex].classList.add("is-active");
				dots[activeIndex]?.classList.add("is-active");
			};

			window.setTimeout(() => {
				showNextImage();
				window.setInterval(showNextImage, cycleInterval);
			}, cycleIndex * cycleStagger);
		});
	}

	document.addEventListener("astro:page-load", setupCaseStudyImageCycles);
</script>
