---
import { Image } from "astro:assets";
interface Props {
	title: string;
	about: string;
	imagePath: ImageMetadata;
	href: string;
	reposityUrl?: string;
}
const { title, about, imagePath, href, reposityUrl } = Astro.props;
---
<div
	class="bg-neutral-100 border border-neutral-200 rounded-2xl w-80 flex flex-col p-4 gap-4"
>
	<a
		href={href}
		target="_blank"
		rel="noopener noreferrer"
		class="w-full aspect-video overflow-hidden rounded-lg border border-neutral-300"
	>
		<Image 
			src={imagePath} 
			alt={`${title}`} 
			class="w-full h-full object-cover rounded-lg" 
		/>
	</a>
	<div class="flex flex-col flex-1 gap-2">
		<h3 class="text-neutral-800 font-bold text-2xl truncate">
			{title}
		</h3>
		<p class="text-neutral-500 text-sm line-clamp-3 flex-1">{about}</p>
		<div class="flex flex-row justify-between items-center w-full">
			<a href={href} target="_blank" rel="noopener noreferrer">
				<button
					class="group flex items-center gap-0 rounded-2xl bg-neutral-900 text-white/95 font-light px-3.5 py-1 hover:bg-brand cursor-pointer transition-all"
				>
					<span>More</span>
					<span
						class="max-w-0 flex items-center overflow-hidden opacity-0 transition-all group-hover:max-w-6 group-hover:opacity-100 ml-1"
					>
						<iconify-icon icon="akar-icons:link-out" height={15}></iconify-icon>
					</span>
				</button>
			</a>
			<div class="flex items-center gap-1">
				<slot />
			</div>
		</div>
	</div>
</div>