---
const { text } = Astro.props;
---

<div class="relative perspective-near mt-10 group w-fit animate-[fadein_0.5s_ease-out_0s_forwards] opacity-0">
	<div
		class="p-px transition-all shadow-lg/50 hover:shadow-xl/50 active:shadow-sm bg-linear-to-b rounded-lg from-neutral-500 via-neutral-900 to-neutral-500 bg-size-[200%_200%] duration-500 hover:scale-105 active:duration-150 active:scale-95"
	>
		<div
			class="rounded-lg transition-all bg-linear-to-b duration-1000 ease-out from-neutral-600 via-neutral-800 to-neutral-600 active:duration-25 active:ease-in active:bg-position-[0_100%] bg-size-[200%_200%]"
		>
			<button
				class="font-bold cursor-pointer bg-linear-to-b from-neutral-900 via-75% via-neutral-800 to-neutral-400 bg-size-[200%_200%] transition-all duration-1000 py-2 px-6 text-2xl bg-clip-text text-transparent drop-shadow-[0_0.5px_1px_rgba(255,255,255,0.1)]"
			>
				{text}
			</button>
		</div>
	</div>
</div>
