---
import PuzzleClient from "./PuzzleClient";
import type { WitnessPalette } from "./PuzzleClient";

interface Props {
	serialized: string;
	theme?: "light" | "dark" | "custom";
	palette?: WitnessPalette;
	sensitivity?: number;
	volume?: number;
	debug?: boolean;
	class?: string;
	id?: string;
}

const {
	serialized,
	theme = "light",
	palette,
	sensitivity = 0.7,
	volume = 0.12,
	debug = false,
	class: className,
	id,
} = Astro.props;
---

<div class="puzzle-wrapper" id={id} data-puzzle-wrapper>
	<PuzzleClient
		client:only="solid-js"
		serialized={serialized}
		theme={theme}
		palette={palette}
		sensitivity={sensitivity}
		volume={volume}
		debug={debug}
		class={className}
	/>
</div>
