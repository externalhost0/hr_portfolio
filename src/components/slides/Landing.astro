<script>
	import { gsap } from "gsap";

	document.getElementById("landing-puzzle")?.addEventListener("puzzle:solved", () => {
		console.log("Puzzle solved!");
		gsap.to("#background-frame", {
			backgroundColor: "#58db81",
			duration: 2,
			ease: "power4.out",
		});
	});
	document.getElementById("landing-puzzle")?.addEventListener("puzzle:failed", () => {
		console.log("Puzzle failed.");
		gsap.to("#background-frame", {
			backgroundColor: "#6b1414",
			duration: 2,
			ease: "power4.out",
		});
	});
	document.getElementById("landing-puzzle")?.addEventListener("puzzle:aborted", () => {
		console.log("Puzzle aborted.");
		gsap.to("#background-frame", {
			backgroundColor: "#705a12",
			duration: 2,
			ease: "power4.out",
		});
	});

	let mainTl = gsap.timeline();

	mainTl.to("#background-frame", {
		backgroundColor: "#f53c20",
		delay: 1,
		duration: 2,
		ease: "power4.out",
	});
	// mainTl.from("#myhandle", {
	//     fontSize: '0px',
	// 	duration: 0.8,
	// 	ease: "back.out(1.7)",
	// }, "<");
	// mainTl.to("#titleheader", {
	//     duration: 1.5,
	//     scale: 0.25,
	//     transformOrigin: "left bottom",
	//     x: "-75vw",
	//     xPercent: 100, // Offsets the negative move so the text stays on screen
	//     y: "50vh",
	//     yPercent: -100,

	//     ease: "expo.inOut"
	// });

	mainTl.play();
</script>
