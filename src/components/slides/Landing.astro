---

<div>
	<main>
		<ASCIIBackground />
		<div class="flex flex-col h-screen justify-center items-center">
			<h1 class="font-bold text-8xl fixed" id="titleheader">
				I'm <span class="text-neutral-300 text-8xl font-caslon" id="myhandle">hayden rivas</span>{" "}!
			</h1>
			<div class="h-90">
				<Puzzle serialized={kBasicDotsSerialized} id="landing-puzzle" theme="custom" palette={kMyPalette} />
			</div>
		</div>
	</main>
</div>

<script>
	import { gsap } from "gsap";

	document.getElementById("landing-puzzle")?.addEventListener("puzzle:solved", () => {
		console.log("Puzzle solved!");
		gsap.to("#background-frame", {
			backgroundColor: "#58db81",
			duration: 2,
			ease: "power4.out",
		});
	});

	document.getElementById("landing-puzzle")?.addEventListener("puzzle:failed", () => {
		console.log("Puzzle failed.");
		gsap.to("#background-frame", {
			backgroundColor: "#6b1414",
			duration: 2,
			ease: "power4.out",
		});
	});

	let mainTl = gsap.timeline();

	mainTl.to("#background-frame", {
		backgroundColor: "#f53c20",
		delay: 1,
		duration: 2,
		ease: "power4.out",
	});
	// mainTl.from("#myhandle", {
	//     fontSize: '0px',
	// 	duration: 0.8,
	// 	ease: "back.out(1.7)",
	// }, "<");
